{
  "name": "EcoleRased",
  "type": "object",
  "properties": {
    "nom": {
      "type": "string",
      "description": "Nom de l'\u00e9cole"
    },
    "type": {
      "type": "string",
      "enum": [
        "Maternelle",
        "\u00c9l\u00e9mentaire",
        "Les deux"
      ],
      "description": "Type d'\u00e9cole"
    },
    "commune": {
      "type": "string",
      "description": "Commune"
    },
    "adresse": {
      "type": "string",
      "description": "Adresse postale compl\u00e8te"
    },
    "telephone": {
      "type": "string",
      "description": "Num\u00e9ro de t\u00e9l\u00e9phone"
    },
    "email": {
      "type": "string",
      "description": "Adresse email de l'\u00e9cole"
    },
    "directeur": {
      "type": "string",
      "description": "Nom du directeur / de la directrice"
    },
    "nombre_classes": {
      "type": "number",
      "description": "Nombre de classes"
    },
    "membres_rased": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs des membres RASED affect\u00e9s"
    },
    "reseau_id": {
      "type": "string",
      "description": "ID du r\u00e9seau"
    }
  },
  "required": [
    "nom"
  ]
}